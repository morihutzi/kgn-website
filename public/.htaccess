  RewriteRule ^bildschirmzeit-kinder-so-gelingt-der-gesunde-umgang/?$ /elternratgeber/medientipps/bildschirmzeit-kinder-so-gelingt-der-gesunde-umgang [R=301,L]
  RewriteRule ^bildschirmzeit-kinder-tipps-medienmentorin/?$ /elternratgeber/medientipps/bildschirmzeit-kinder-tipps-medienmentorin [R=301,L]
  RewriteRule ^brawl-stars-altersfreigabe-ist-das-spiel-fuer-kinder-geeignet/?$ /elternratgeber/medientipps/brawl-stars-altersfreigabe-ist-das-spiel-fuer-kinder-geeignet [R=301,L]
  RewriteRule ^cybergrooming-rtl-dokumentation-risiken-kinder/?$ /elternratgeber/medientipps/cybergrooming-rtl-dokumentation-risiken-kinder [R=301,L]
  RewriteRule ^cybermobbing-beispiele-erkennen-verstehen-und-kinder-schuetzen/?$ /elternratgeber/medientipps/cybermobbing-beispiele-erkennen-verstehen-und-kinder-schuetzen [R=301,L]
  RewriteRule ^darknet-was-eltern-wissen-muessen-gefahren-und-schutzmassnahmen-fuer-kinder/?$ /elternratgeber/medientipps/darknet-was-eltern-wissen-muessen-gefahren-und-schutzmassnahmen-fuer-kinder [R=301,L]
  RewriteRule ^deepfakes-deepnudes-wenn-kuenstliche-intelligenz-zur-bedrohung-fuer-unsere-kinder-wird/?$ /elternratgeber/medientipps/deepfakes-deepnudes-wenn-kuenstliche-intelligenz-zur-bedrohung-fuer-unsere-kinder-wird [R=301,L]
