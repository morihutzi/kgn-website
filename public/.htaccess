# ============================================================================
# kidgonet.de – statischer Export (Next.js `output: "export"`)
# Übernimmt die Header/Redirects, die Next bei `output: export` ignoriert.
# Liegt in public/ und wird beim Build nach out/ kopiert (siehe build-Skript).
# ============================================================================

# --- Saubere URLs ----------------------------------------------------------
# Next erzeugt z. B. `preise.html` und einen Ordner `preise/` (nur RSC-Payloads,
# kein index.html). DirectorySlash würde /preise -> /preise/ umleiten und ins
# Leere laufen – daher abschalten und gezielt auf die .html-Datei rewriten.
DirectorySlash Off
Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Trailing-Slash -> kanonische URL ohne Slash (301). Ohne das laeuft /preise/
  # in den RSC-Ordner /preise/ (kein index.html) und Apache liefert 403 Forbidden.
  # $1 stammt aus dem RewriteRule-Pattern (ohne Slash); die Bedingung greift nur,
  # wenn dazu eine .html existiert, damit echte Asset-Ordner unberuehrt bleiben.
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^(.+?)/$ /$1 [R=301,L]

  # /preise -> /preise.html (auch wenn ein RSC-Ordner /preise/ existiert)
  RewriteCond %{REQUEST_FILENAME}\.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]

  # Falsch geschriebene URL (grosses D) aus aelteren iOS-App-Builds abfangen.
  # Der Server ist case-sensitiv, daher liefert /Datenschutz-ios-app/ sonst 404.
  RewriteRule ^Datenschutz-ios-app/?$ /datenschutz-ios-app [R=301,L]

  # 301-Redirects (alte, noch indexierte URLs aus der früheren Live-Seite)
  RewriteRule ^installation-der-kidgonet-app-auf-android-geraeten-schnell-einfach/?$ /hilfe/installation-android [R=301,L]
  RewriteRule ^kindersicherung-handy-2025/?$ /elternratgeber/medientipps/kindersicherung-handy-2025 [R=301,L]

  # Partner-Landingpage umbenannt: "Stark am Ball" -> "Initiative Digitale Balance".
  RewriteRule ^stark-am-ball/?$ /digitale-balance [R=301,L]

  # --- Elternratgeber-Artikel: alte flache WordPress-URLs -> neue Struktur ----
  # Generiert aus dem `originalUrl`-Frontmatter der MDX-Artikel. Erhaelt die
  # ueber Jahre aufgebaute Ranking-Autoritaet beim Relaunch (sonst 404).
  RewriteRule ^bayerischer-digitalpreis-b-digital-2025-minister-mehring-ehrt-kidgonet-gruender-und-manuel-neuer-fuer-engagement-im-kinderschutz-und-digitaler-verantwortung/?$ /elternratgeber/expert-talk/bayerischer-digitalpreis-b-digital-2025-minister-mehring-ehrt-kidgonet-gruender-und-manuel-neuer-fuer-engagement-im-kinderschutz-und-digitaler-verantwortung [R=301,L]
  RewriteRule ^das-erste-handy-fuer-dein-kind-so-gelingt-der-start-in-die-digitale-welt-mit-verantwortung/?$ /elternratgeber/expert-talk/das-erste-handy-fuer-dein-kind-so-gelingt-der-start-in-die-digitale-welt-mit-verantwortung [R=301,L]
  RewriteRule ^digitaler-kinderschutz-sara-flieder-ueber-risiken-eltern-tipps-und-sichere-zukunft/?$ /elternratgeber/expert-talk/digitaler-kinderschutz-sara-flieder-ueber-risiken-eltern-tipps-und-sichere-zukunft [R=301,L]
  RewriteRule ^erste-handy-kind-tipps-mirjam-lamberti/?$ /elternratgeber/expert-talk/erste-handy-kind-tipps-mirjam-lamberti [R=301,L]
  RewriteRule ^expert-talk-mit-steven-in-drei-phasen-zum-ersten-eigenen-handy-so-begleitest-du-dein-kind-in-die-digitale-welt/?$ /elternratgeber/expert-talk/expert-talk-mit-steven-in-drei-phasen-zum-ersten-eigenen-handy-so-begleitest-du-dein-kind-in-die-digitale-welt [R=301,L]
  RewriteRule ^expert-talk-mit-susanne-jansen-digitale-erziehung-zwischen-chancen-und-herausforderungen/?$ /elternratgeber/expert-talk/expert-talk-mit-susanne-jansen-digitale-erziehung-zwischen-chancen-und-herausforderungen [R=301,L]
  RewriteRule ^handy-fuer-kinder-ab-wann-tipps-von-lea-lanzinger/?$ /elternratgeber/expert-talk/handy-fuer-kinder-ab-wann-tipps-von-lea-lanzinger [R=301,L]
  RewriteRule ^handynutzung-bei-kindern-interview-mit-christopher-end-zu-regeln-bildschirmzeit-und-elternrolle/?$ /elternratgeber/expert-talk/handynutzung-bei-kindern-interview-mit-christopher-end-zu-regeln-bildschirmzeit-und-elternrolle [R=301,L]
  RewriteRule ^interview-annika-bremerich-handy-fuer-kinder/?$ /elternratgeber/expert-talk/interview-annika-bremerich-handy-fuer-kinder [R=301,L]
  RewriteRule ^interview-manuel-neuer/?$ /elternratgeber/expert-talk/interview-manuel-neuer [R=301,L]
  RewriteRule ^interview-mit-aline-fink-medienerziehung-fuer-kinder/?$ /elternratgeber/expert-talk/interview-mit-aline-fink-medienerziehung-fuer-kinder [R=301,L]
  RewriteRule ^joachim-schuch-wie-smartphones-die-entwicklung-unserer-kinder-formen/?$ /elternratgeber/expert-talk/joachim-schuch-wie-smartphones-die-entwicklung-unserer-kinder-formen [R=301,L]
  RewriteRule ^kind-staendig-am-handy-tipps-elterncoach/?$ /elternratgeber/expert-talk/kind-staendig-am-handy-tipps-elterncoach [R=301,L]
  RewriteRule ^kinder-und-ki-chancen-und-risiken-im-alltag-interview-mit-laura-tzanev/?$ /elternratgeber/expert-talk/kinder-und-ki-chancen-und-risiken-im-alltag-interview-mit-laura-tzanev [R=301,L]
  RewriteRule ^lars-brockmann-ueber-medienerziehung/?$ /elternratgeber/expert-talk/lars-brockmann-ueber-medienerziehung [R=301,L]
  RewriteRule ^medienerziehung-fuer-kinder-expert-talk-mit-margarete-berger-ueber-gesunde-bildschirmzeit/?$ /elternratgeber/expert-talk/medienerziehung-fuer-kinder-expert-talk-mit-margarete-berger-ueber-gesunde-bildschirmzeit [R=301,L]
  RewriteRule ^medienerziehung-in-der-familie-tipps/?$ /elternratgeber/expert-talk/medienerziehung-in-der-familie-tipps [R=301,L]
  RewriteRule ^medienerziehung-kinder-interview-nadia-polat/?$ /elternratgeber/expert-talk/medienerziehung-kinder-interview-nadia-polat [R=301,L]
  RewriteRule ^nina-franz/?$ /elternratgeber/expert-talk/nina-franz [R=301,L]
  RewriteRule ^philine-schwalbach/?$ /elternratgeber/expert-talk/philine-schwalbach [R=301,L]
  RewriteRule ^sascha-amrhein-digitale-medien-in-der-kita/?$ /elternratgeber/expert-talk/sascha-amrhein-digitale-medien-in-der-kita [R=301,L]
  RewriteRule ^selbstregulation-fuer-kinder-ein-interview-mit-stefanie-froehlich/?$ /elternratgeber/expert-talk/selbstregulation-fuer-kinder-ein-interview-mit-stefanie-froehlich [R=301,L]
  RewriteRule ^zwischen-anspruechen-und-alltagschaos-perfektionismus-in-der-elternschaft-loslassen/?$ /elternratgeber/expert-talk/zwischen-anspruechen-und-alltagschaos-perfektionismus-in-der-elternschaft-loslassen [R=301,L]
  RewriteRule ^ab-wie-viel-jahren-ist-snapchat-erlaubt-das-sollten-eltern-wissen/?$ /elternratgeber/medientipps/ab-wie-viel-jahren-ist-snapchat-erlaubt-das-sollten-eltern-wissen [R=301,L]
  RewriteRule ^alexa-im-kinderzimmer-warum-sprachassistenten-noch-nicht-ideal-sind/?$ /elternratgeber/medientipps/alexa-im-kinderzimmer-warum-sprachassistenten-noch-nicht-ideal-sind [R=301,L]
  RewriteRule ^beispiele-fuer-fake-news-wie-kinder-wahrheit-von-luege-unterscheiden-lernen/?$ /elternratgeber/medientipps/beispiele-fuer-fake-news-wie-kinder-wahrheit-von-luege-unterscheiden-lernen [R=301,L]
  RewriteRule ^bildschirmzeit-12-jahre-tipps-empfehlungen/?$ /elternratgeber/medientipps/bildschirmzeit-12-jahre-tipps-empfehlungen [R=301,L]
  RewriteRule ^bildschirmzeit-app-fuer-familien-sicher-ohne-ueberwachung/?$ /elternratgeber/medientipps/bildschirmzeit-app-fuer-familien-sicher-ohne-ueberwachung [R=301,L]
